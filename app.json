{
  "expo": {
    "name": "Dayxo",
    "slug": "dayxo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F7F7F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dayxo.app"
    },
    "android": {
      "package": "com.dayxo.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
